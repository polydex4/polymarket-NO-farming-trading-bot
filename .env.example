# =============================================================================
# Polymarket NO Farming Bot — single root .env (backend + dashboard)
#
# Quick start:  cp .env.example .env
# Edit here OR use Dashboard → Settings (wallet/mode/strategy).
# Restart both `python -m bot.main` and `npm run dev` after changes.
# =============================================================================

# --- Dashboard (Next.js) ---
# URL where the UI calls the bot REST API (change if bot runs elsewhere)
NEXT_PUBLIC_BOT_API_URL=http://localhost:8080
# WebSocket URL for live portfolio/trades on the dashboard
NEXT_PUBLIC_BOT_WS_URL=ws://localhost:8080/ws

# --- Bot API ---
# Port the Python bot listens on (default 8080)
API_PORT=8080
# Allowed dashboard origins, comma-separated (add your domain for production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000

# --- Trading mode ---
# paper = simulated orders | live = real Polymarket orders (requires wallet below)
BOT_MODE=paper
# Must be true to send real orders (only applies when BOT_MODE=live)
LIVE_TRADING_ENABLED=false
# true = log orders but do not send | false = send orders when live is enabled
DRY_RUN=true
# true = fake balance + no real bets, but still uses live Polymarket market data
DEMO_MODE=true
# Simulated starting balance shown in demo mode (USD)
DEMO_BALANCE=7535
# Simulated session profit/loss shown in demo mode (USD)
DEMO_SESSION_PNL=732

# --- Wallet (required for live trading) ---
# Your Polygon wallet private key (never commit — keep .env out of git)
PRIVATE_KEY=
# Polymarket proxy/funder address (required for signature_type 1 or 2)
FUNDER_ADDRESS=
# Postgres URL for trade history (optional for paper/demo)
DATABASE_URL=
# Polygon RPC endpoint (required for live on-chain actions)
POLYGON_RPC_URL=

# --- Optional: dashboard CLI logging ---
# debug | info | warn | error | silent
LOG_LEVEL=info
LOG_TIMESTAMPS=false
LOG_COLOR=true
